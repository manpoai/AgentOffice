# ASuite Shell — environment template
# Copy to .env.local and fill in your values:
#   cp .env.example .env.local

# Gateway connection
NEXT_PUBLIC_GATEWAY_URL=http://localhost:4000
GATEWAY_URL=http://localhost:4000

# Agent token for Gateway API (generate with: openssl rand -hex 32)
GATEWAY_AGENT_TOKEN=

# JWT secret — MUST match the gateway's JWT_SECRET
JWT_SECRET=

# Baserow credentials (for service-tokens API)
BR_URL=http://localhost:8280
BR_EMAIL=admin@asuite.local
BR_PASSWORD=

# Mattermost (optional, only if IM is enabled)
# MM_URL=http://localhost:8065
# NEXT_PUBLIC_MM_URL=https://mm.example.com
