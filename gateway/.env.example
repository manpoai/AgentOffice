# ASuite Gateway Configuration
# Copy this file to .env and fill in values as needed.

# ─── Gateway ────────────────────────────────────────
# Port the gateway listens on (default: 4000)
GATEWAY_PORT=4000

# Path to the SQLite database file (default: ./gateway.db)
GATEWAY_DB_PATH=

# ─── Authentication ─────────────────────────────────
# Static admin token for API access. If not set, a random one is generated on each start.
ADMIN_TOKEN=

# Secret key for signing JWT tokens. If not set, a random one is generated on each start.
# WARNING: Random generation means JWTs are invalidated on restart. Set a stable value in production.
JWT_SECRET=

# Default password for the auto-created admin user. If not set, a random one is generated on first start.
ADMIN_PASSWORD=

# ─── CORS ───────────────────────────────────────────
# Allowed origin for CORS (default: http://localhost:3101)
CORS_ORIGIN=http://localhost:3101

# ─── Baserow (Database backend) ────────────────────
# URL of the Baserow instance (default: http://localhost:8280)
BASEROW_URL=http://localhost:8280

# Baserow admin credentials for API operations
BASEROW_EMAIL=
BASEROW_PASSWORD=

# Baserow database ID to operate on
BASEROW_DATABASE_ID=

# Baserow database token for row-level operations
BASEROW_TOKEN=
